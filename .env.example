# ── LLM ──────────────────────────────────────────────────────────────────────
# Tu Gemini API key (de https://aistudio.google.com/apikey)
BUILT_IN_FORGE_API_KEY=AIza...tu_clave_aqui

# URL del endpoint (dejar en blanco para usar Gemini por defecto)
# BUILT_IN_FORGE_API_URL=https://generativelanguage.googleapis.com/v1beta/openai/chat/completions

# ── Base de datos MySQL ───────────────────────────────────────────────────────
# Formato: mysql://usuario:contraseña@host:puerto/nombre_db
DATABASE_URL=mysql://root:password@localhost:3306/handoff

# ── Autenticación ─────────────────────────────────────────────────────────────
# Secreto para firmar las cookies de sesión (genera uno random, mínimo 32 chars)
JWT_SECRET=cambia_esto_por_un_secreto_largo_y_aleatorio_32chars

# ── App ───────────────────────────────────────────────────────────────────────
# ID de la aplicación (puede ser cualquier string único)
VITE_APP_ID=handoff

# ── Opcionales ────────────────────────────────────────────────────────────────
# Para notificaciones de errores al dueño de la app
# OWNER_OPEN_ID=

# Para almacenamiento de archivos en S3 (opcional)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=
# AWS_S3_BUCKET=
